/*
 * 文件名：serial_loopback.c
 * 功能：Linux串口回环测试程序，验证串口全链路（硬件/驱动/应用层）
 * 编译：arm-linux-gnueabihf-gcc serial_loopback.c -o serial_loopback
 * 运行：./serial_loopback /dev/ttymxc0 115200
 * 硬件要求：将串口TX引脚与RX引脚短接，实现物理回环
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <fcntl.h>
#include <termios.h>
#include <errno.h>
#include <stdint.h>

// -------------------------- 宏定义与常量 --------------------------
#define BUF_SIZE  1024    // 收发缓冲区大小
#define TEST_CNT  5       // 测试次数
#define TIMEOUT_SEC 5     // 接收超时时间（秒）

// -------------------------- 工具函数：波特率映射 --------------------------
// 功能：将用户输入的波特率数值，转换为termios结构体对应的波特率宏
speed_t get_baudrate(int baud)
{
    switch(baud)
    {
        case 9600:    return B9600;
        case 19200:   return B19200;
        case 38400:   return B38400;
        case 57600:   return B57600;
        case 115200:  return B115200;
        case 230400:  return B230400;
        case 460800:  return B460800;
        case 921600:  return B921600;
        default:
            fprintf(stderr, "错误：不支持的波特率 %d\n", baud);
            exit(EXIT_FAILURE);
    }
}

// -------------------------- 串口初始化函数 --------------------------
// 功能：打开串口、配置串口参数（波特率/数据位/校验位/停止位）、设置原始模式
int serial_init(const char *dev_path, speed_t baud)
{
    int fd;
    struct termios options;

    // 1. 打开串口设备（Linux下一切皆文件，串口以文件形式操作）
    // O_RDWR：读写模式；O_NOCTTY：不将串口作为控制终端，避免进程被信号中断
    // O_NDELAY：非阻塞打开，后续通过VTIME/VMIN设置阻塞超时
    fd = open(dev_path, O_RDWR | O_NOCTTY | O_NDELAY);
    if (fd < 0)
    {
        perror("open serial port failed");  // perror自动打印错误原因
        exit(EXIT_FAILURE);
    }

    // 2. 恢复串口为阻塞状态（覆盖O_NDELAY，通过VTIME/VMIN实现超时阻塞）
    if (fcntl(fd, F_SETFL, 0) < 0)
    {
        perror("fcntl set block failed");
        close(fd);
        exit(EXIT_FAILURE);
    }

    // 3. 获取串口当前配置（tcgetattr：获取终端属性，termios结构体核心API）
    if (tcgetattr(fd, &options) < 0)
    {
        perror("tcgetattr failed");
        close(fd);
        exit(EXIT_FAILURE);
    }

    // 4. 设置波特率（cfsetispeed：输入波特率；cfsetospeed：输出波特率）
    // 串口全双工，收发波特率必须一致
    cfsetispeed(&options, baud);
    cfsetospeed(&options, baud);

    // 5. 配置控制模式（c_cflag：控制标志位，硬件相关配置）
    // CLOCAL：本地连接，不检测调制解调器控制信号（嵌入式串口必备）
    // CREAD：使能接收，允许串口接收数据
    options.c_cflag |= (CLOCAL | CREAD);

    // 配置数据位：8位（CS8），先清除数据位掩码，再设置
    options.c_cflag &= ~CSIZE;  // 清除数据位相关标志
    options.c_cflag |= CS8;     // 8位数据位（嵌入式串口标准配置：8N1）

    // 配置停止位：1位（不设置CSTOPB即为1位，设置则为2位）
    options.c_cflag &= ~CSTOPB;

    // 配置校验位：无校验（不设置PARENB即为无校验）
    options.c_cflag &= ~PARENB;

    // 6. 配置本地模式（c_lflag：本地标志位，行规层核心控制）
    // 关闭所有终端特殊处理，设置为原始模式（Raw Mode），透传数据
    // ICANON：关闭规范模式（行缓冲），数据直接透传，不等待回车
    // ECHO/ECHOE：关闭回显，避免发送的数据被回显到终端
    // ISIG：关闭信号处理，不响应Ctrl+C等特殊字符
    options.c_lflag &= ~(ICANON | ECHO | ECHOE | ISIG);

    // 7. 配置输入模式（c_iflag：输入标志位，输入数据处理）
    // 关闭软件流控（IXON/IXOFF/IXANY），关闭输入转换
    options.c_iflag &= ~(IXON | IXOFF | IXANY);
    // 关闭输入字符转换（如\n转\r\n），保证数据透传
    options.c_iflag &= ~(INLCR | ICRNL | IGNCR);

    // 8. 配置输出模式（c_oflag：输出标志位，输出数据处理）
    // 关闭所有输出转换，保证数据透传
    options.c_oflag &= ~OPOST;

    // 9. 配置超时与最小字符（c_cc：控制字符数组，阻塞模式核心配置）
    // VMIN：最小读取字符数，0表示不等待字符，超时即返回
    // VTIME：超时时间，单位0.1秒，50对应5秒超时
    options.c_cc[VMIN] = 0;
    options.c_cc[VTIME] = TIMEOUT_SEC * 10;

    // 10. 应用配置（TCSANOW：立即生效，不等待数据传输完成）
    if (tcsetattr(fd, TCSANOW, &options) < 0)
    {
        perror("tcsetattr failed");
        close(fd);
        exit(EXIT_FAILURE);
    }

    // 11. 清空串口缓冲区（TCIFLUSH：清空输入缓冲区；TCOFLUSH：清空输出缓冲区）
    tcflush(fd, TCIOFLUSH);

    printf("串口 %s 初始化成功，波特率 %d\n", dev_path, (int)baud);
    return fd;
}

// -------------------------- 串口发送函数 --------------------------
// 功能：向串口发送指定长度的数据，返回实际发送的字节数
ssize_t serial_send(int fd, const uint8_t *buf, size_t len)
{
    ssize_t ret;

    if (fd < 0 || buf == NULL || len == 0)
    {
        fprintf(stderr, "serial_send 参数错误\n");
        return -1;
    }

    // write系统调用：向文件描述符（串口）写入数据
    // 串口是字符设备，write会将数据放入内核发送缓冲区，由UART驱动发送
    ret = write(fd, buf, len);
    if (ret < 0)
    {
        perror("write failed");
        return -1;
    }
    else if (ret != len)
    {
        fprintf(stderr, "警告：发送不完整，预期 %zu 字节，实际发送 %zd 字节\n", len, ret);
    }

    return ret;
}

// -------------------------- 串口接收函数 --------------------------
// 功能：从串口接收指定长度的数据，返回实际接收的字节数
ssize_t serial_recv(int fd, uint8_t *buf, size_t len)
{
    ssize_t ret;
    size_t total = 0;

    if (fd < 0 || buf == NULL || len == 0)
    {
        fprintf(stderr, "serial_recv 参数错误\n");
        return -1;
    }

    // 循环读取，直到收到指定长度数据或超时
    while (total < len)
    {
        // read系统调用：从文件描述符（串口）读取数据
        // 阻塞模式下，超时后返回0，数据到达时返回实际读取字节数
        ret = read(fd, buf + total, len - total);
        if (ret < 0)
        {
            perror("read failed");
            return -1;
        }
        else if (ret == 0)
        {
            // 超时，返回已读取的字节数
            break;
        }
        total += ret;
    }

    return total;
}

// -------------------------- 主函数：回环测试逻辑 --------------------------
int main(int argc, char *argv[])
{
    int fd;
    speed_t baud;
    uint8_t send_buf[BUF_SIZE];
    uint8_t recv_buf[BUF_SIZE];
    ssize_t send_len, recv_len;
    int i, j;

    // 1. 参数校验
    if (argc != 3)
    {
        fprintf(stderr, "用法：%s <串口设备路径> <波特率>\n", argv[0]);
        fprintf(stderr, "示例：%s /dev/ttymxc0 115200\n", argv[0]);
        exit(EXIT_FAILURE);
    }

    // 2. 解析波特率
    baud = get_baudrate(atoi(argv[2]));

    // 3. 初始化串口
    fd = serial_init(argv[1], baud);

    // 4. 初始化发送缓冲区（填充递增数据，方便校验）
    for (i = 0; i < BUF_SIZE; i++)
    {
        send_buf[i] = (uint8_t)(i % 256);  // 0~255循环填充
    }

    printf("开始串口回环测试，测试次数：%d，数据长度：%d\n", TEST_CNT, BUF_SIZE);

    // 5. 循环测试
    for (i = 0; i < TEST_CNT; i++)
    {
        printf("\n=== 第 %d 次测试 ===\n", i + 1);

        // 清空接收缓冲区
        tcflush(fd, TCIFLUSH);

        // 6. 发送数据
        send_len = serial_send(fd, send_buf, BUF_SIZE);
        if (send_len < 0)
        {
            fprintf(stderr, "第 %d 次发送失败\n", i + 1);
            continue;
        }
        printf("发送成功，长度：%zd\n", send_len);

        // 7. 接收数据
        recv_len = serial_recv(fd, recv_buf, BUF_SIZE);
        if (recv_len < 0)
        {
            fprintf(stderr, "第 %d 次接收失败\n", i + 1);
            continue;
        }
        printf("接收成功，长度：%zd\n", recv_len);

        // 8. 数据校验
        if (recv_len != send_len)
        {
            fprintf(stderr, "错误：收发长度不一致！发送：%zd，接收：%zd\n", send_len, recv_len);
            continue;
        }

        if (memcmp(send_buf, recv_buf, BUF_SIZE) != 0)
        {
            fprintf(stderr, "错误：数据不一致！\n");
            // 打印错误位置（可选，调试用）
            for (j = 0; j < BUF_SIZE; j++)
            {
                if (send_buf[j] != recv_buf[j])
                {
                    fprintf(stderr, "位置 %d：发送 0x%02X，接收 0x%02X\n", j, send_buf[j], recv_buf[j]);
                    break;
                }
            }
        }
        else
        {
            printf("测试通过！数据一致\n");
        }
    }

    // 9. 关闭串口
    close(fd);
    printf("\n测试完成\n");

    return 0;
}





一、代码功能说明
核心功能：串口回环测试（将串口 TX 引脚短接 RX 引脚，程序发送数据后自动接收，验证串口硬件 / 驱动 / 应用层全链路正常）
专业特性：
完整的串口参数配置（波特率、数据位、校验位、停止位）
原始模式（Raw Mode）配置，关闭行规层所有特殊处理，透传数据
超时控制、错误处理、数据校验
支持自定义波特率、测试数据长度、测试次数
符合 POSIX 标准，可在 x86/ARM 嵌入式 Linux 上直接运行POSIX = Portable Operating System Interface（可移植操作系统接口）
  



  #include <stdio.h>      // 标准输入输出（printf/fprintf）
#include <stdlib.h>     // 标准库（exit/atoi）
#include <string.h>     // 字符串操作（memcpy/memcmp）
#include <unistd.h>     // POSIX系统调用（close/write/read/fcntl）
#include <fcntl.h>      // 文件控制（open/O_RDWR/O_NOCTTY）
#include <termios.h>    // 终端IO控制（termios结构体/tcgetattr/tcsetattr，串口核心API）
#include <errno.h>      // 错误码（perror）
#include <stdint.h>     // 标准整数类型（uint8_t，保证跨平台兼容性）
  
  
核心头文件termios.h：Linux 终端 / 串口编程的核心，定义了struct termios结构体，所有串口参数配置都通过这个结构体实现，对应你学的行规层 / TTY 驱动层的配置接口。
  

  宏定义部分
  #define BUF_SIZE  1024    // 收发缓冲区大小
#define TEST_CNT  5       // 测试次数
#define TIMEOUT_SEC 5     // 接收超时时间（秒）
宏定义提高代码可维护性，修改参数无需改动核心逻辑。
  

  3. 波特率映射函数get_baudrate
  speed_t get_baudrate(int baud)
{
    switch(baud)
    {
        case 9600:    return B9600;
        // ...其他波特率
        default:
            fprintf(stderr, "错误：不支持的波特率 %d\n", baud);
            exit(EXIT_FAILURE);
    }
}
底层原理：struct termios的波特率不是直接填数值，而是用内核定义的宏（如B115200），这些宏对应 UART 硬件的波特率分频值，函数实现了「用户输入数值→内核宏」的转换。
对应硬件：波特率宏最终会被 UART 驱动写入硬件寄存器，配置 UART 的发送 / 接收时钟。
  
  
4. 串口初始化函数serial_init（核心中的核心）
  fd = open(dev_path, O_RDWR | O_NOCTTY | O_NDELAY);
O_RDWR：读写模式，串口需要同时收发数据。
O_NOCTTY：关键参数，不将串口作为进程的控制终端，避免进程收到SIGINT等信号意外退出（嵌入式串口必备）。
O_NDELAY：非阻塞打开，后续通过fcntl恢复阻塞，用VTIME/VMIN实现超时控制。
底层原理：Linux 下一切皆文件，串口对应/dev/ttyxxx设备文件，open会触发 TTY 驱动的open回调，初始化 UART 硬件。
（2）设置阻塞模式
fcntl(fd, F_SETFL, 0);
fcntl是文件控制系统调用，F_SETFL设置文件状态标志，0 表示清除O_NDELAY，恢复阻塞模式。
后续通过VTIME/VMIN实现「带超时的阻塞」，避免read无限等待。
（3）获取当前串口配置
tcgetattr(fd, &options);
tcgetattr：获取终端属性，将串口当前配置填充到struct termios结构体。
底层原理：TTY 驱动层会将当前 UART 硬件的配置（波特率、数据位等）同步到termios结构体，保证配置的完整性。
（4）设置波特率
cfsetispeed(&options, baud);
cfsetospeed(&options, baud);
cfsetispeed：设置输入波特率（RX）；cfsetospeed：设置输出波特率（TX）。
底层原理：UART 是全双工，收发波特率必须一致，函数会将波特率宏写入termios的c_cflag，最终由 UART 驱动配置硬件时钟。

  
（5）配置控制模式c_cflag
options.c_cflag |= (CLOCAL | CREAD);
options.c_cflag &= ~CSIZE;
options.c_cflag |= CS8;
options.c_cflag &= ~CSTOPB;
options.c_cflag &= ~PARENB;
CLOCAL：本地模式，不检测调制解调器信号（嵌入式串口无调制解调器，必须设置）。
CREAD：使能接收，UART 硬件才能接收数据（不设置则无法接收）。
CS8：8 位数据位，CSIZE是数据位掩码，先清除再设置，避免残留配置。
CSTOPB：1 位停止位（不设置则为 1 位，设置则为 2 位）。
PARENB：无校验（不设置则无校验，设置则使能校验）。
对应硬件：这些标志位最终会被 UART 驱动写入硬件寄存器，配置 UART 的帧格式（8N1，嵌入式串口标准）。

  
（6）配置本地模式c_lflag（行规层核心）
options.c_lflag &= ~(ICANON | ECHO | ECHOE | ISIG);
ICANON：规范模式（行缓冲），关闭后进入原始模式，数据直接透传，不等待回车（串口通信必须关闭）。
ECHO/ECHOE：回显，关闭后输入的字符不会回显到终端（避免发送的数据被回显）。
ISIG：信号处理，关闭后不响应Ctrl+C等特殊字符（避免数据中的0x03被误判为SIGINT）。
底层原理：这些标志位控制 ** 行规层n_tty** 的行为，关闭后行规层不再做任何数据处理，完全透传，对应你学的「原始模式」。

  
（7）配置输入 / 输出模式c_iflag/c_oflag
options.c_iflag &= ~(IXON | IXOFF | IXANY);
options.c_iflag &= ~(INLCR | ICRNL | IGNCR);
options.c_oflag &= ~OPOST;
IXON/IXOFF/IXANY：软件流控，关闭后不处理XON/XOFF字符，保证数据透传。
INLCR/ICRNL/IGNCR：输入字符转换，关闭后不将\n转\r\n，保证数据原始性。
OPOST：输出处理，关闭后不做任何输出转换，数据直接透传。

  
（8）配置超时c_cc
options.c_cc[VMIN] = 0;
options.c_cc[VTIME] = TIMEOUT_SEC * 10;
VMIN：最小读取字符数，0 表示不等待字符，超时即返回。
VTIME：超时时间，单位 0.1 秒，50 对应 5 秒超时。
底层原理：控制read系统调用的阻塞行为，实现「带超时的阻塞读取」，避免程序卡死。

  
（9）应用配置与清空缓冲区
tcsetattr(fd, TCSANOW, &options);
tcflush(fd, TCIOFLUSH);
tcsetattr：将配置写入 TTY 驱动，TCSANOW表示立即生效。
tcflush：清空串口缓冲区，TCIOFLUSH同时清空输入 / 输出缓冲区，避免残留数据影响测试。

  
5. 发送 / 接收函数
（1）发送函数serial_send
ret = write(fd, buf, len);
底层原理：write系统调用触发 TTY 驱动的write回调，数据依次经过TTY 驱动层→行规层→UART 驱动层，最终由 UART 硬件发送到 TX 引脚。
行规层在原始模式下不做任何处理，数据完全透传。
（2）接收函数serial_recv
ret =read(fd, buf + total, len - total);
底层原理：UART 硬件收到数据后触发中断，UART 驱动将数据上报给行规层，行规层透传后放入 TTY 驱动缓冲区，read从缓冲区读取数据。
循环读取保证收到完整的测试数据，超时后返回。

  
6. 主函数逻辑
参数校验：检查用户输入的串口设备和波特率。
初始化发送缓冲区：填充递增数据（0~255 循环），方便校验数据一致性。
循环测试：发送→接收→校验，验证串口全链路正常。
数据校验：通过memcmp对比收发数据，验证数据完整性。
关闭串口：close系统调用触发 TTY 驱动的close回调，关闭 UART 硬件。
  UART = Universal Asynchronous Receiver/Transmitter
通用异步收发器
它就是一个硬件电路模块，负责：
把芯片内部的并行数据 → 转成一根线上的串行数据发出去（TX）
把一根线上来的串行数据 → 转回芯片内部的并行数据（RX）
  


   
