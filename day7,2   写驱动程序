  最重要结构体：file_operations（桥梁）
static struct file_operations hello_drv = {
    .owner = THIS_MODULE,
    .open = hello_drv_open,
    .read = hello_drv_read,
    .write = hello_drv_write,
    .release = hello_drv_close,
};
这是什么？
这是 用户 APP ↔ 内核 ↔ 驱动 的桥梁！
原理
用户调用：
open() → 找 .open
read() → 找 .read
write() → 找 .write
close() → 找 .release
内核只认这个结构体！
格式固定吗？
100% 固定！
所有字符设备驱动都必须定义这个结构体！


入口函数：加载驱动时执行
static int __init hello_init(void)
{
    printk("hello_init\n");

    // 注册字符设备，major=0 自动分配主设备号
    major = register_chrdev(0, "hello", &hello_drv);

    // 创建 class，用于自动生成设备节点
    hello_class = class_create(THIS_MODULE, "hello_class");

    // 创建设备文件 /dev/hello
    device_create(hello_class, NULL, MKDEV(major, 0), NULL, "hello");

    return 0;
}
